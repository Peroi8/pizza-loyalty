# === SUPABASE ===
NEXT_PUBLIC_SUPABASE_URL=https://DEIN-PROJEKT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...dein-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJ...dein-service-role-key

# === APPLE WALLET ===
# Pass Type Identifier (z.B. pass.com.deinepizzeria.loyalty)
APPLE_PASS_TYPE_ID=pass.com.example.loyalty
# Team ID aus Apple Developer Portal
APPLE_TEAM_ID=XXXXXXXXXX
# Pfad zu den Zertifikaten (werden in /certs/ Ordner abgelegt)
APPLE_PASS_CERT_PATH=./certs/signerCert.pem
APPLE_PASS_KEY_PATH=./certs/signerKey.pem
APPLE_WWDR_CERT_PATH=./certs/WWDR.pem
APPLE_PASS_KEY_PASSPHRASE=dein-passwort

# === GOOGLE WALLET ===
# Google Cloud Service Account Email
GOOGLE_SERVICE_ACCOUNT_EMAIL=wallet@dein-projekt.iam.gserviceaccount.com
# Pfad zum Service Account Private Key
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./certs/google-service-account.json
# Google Wallet Issuer ID
GOOGLE_WALLET_ISSUER_ID=1234567890
# Google Wallet Class ID (wird beim ersten Start automatisch erstellt)
GOOGLE_WALLET_CLASS_ID=loyalty-pizza

# === AI KASSENZETTEL-SCANNER ===
# Anthropic API Key (fuer Claude Haiku Vision)
# Bekommt man auf: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...dein-key

# === APP ===
NEXT_PUBLIC_APP_URL=http://localhost:3000
ADMIN_PASSWORD=dein-admin-passwort

# === PIZZERIA BRANDING ===
NEXT_PUBLIC_PIZZERIA_NAME=Ciao Napoli
NEXT_PUBLIC_POINTS_PER_EURO=1
NEXT_PUBLIC_PRIMARY_COLOR=#e53e3e
